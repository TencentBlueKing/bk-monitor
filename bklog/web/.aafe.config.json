{
  "runtime": ".ai-agent",
  "template": "complex",
  "memory": {
    "enabled": true,
    "path": ".ai-agent/memory",
    "categories": [
      "design",
      "component",
      "habit",
      "convention",
      "decision",
      "experience",
      "learning"
    ],
    "dedupe": true,
    "summary": true,
    "experience": {
      "enabled": true,
      "triggerAfterAttempts": 3,
      "writeOnlyAfterSuccess": true,
      "record": [
        "problem_signature",
        "success_path",
        "decision_path",
        "reuse_boundary",
        "avoid"
      ]
    }
  },
  "framework": "vue",
  "frameworks": [
    "vue"
  ],
  "scenarios": [
    "complex",
    "dashboard",
    "patterns",
    "ddd"
  ],
  "editors": [
    "cursor",
    "codebuddy"
  ],
  "packs": {
    "frameworks": [
      "vue"
    ],
    "scenarios": [
      "complex",
      "dashboard",
      "patterns",
      "ddd"
    ]
  },
  "recommendedPackages": [
    "@aafe/core",
    "@aafe/vue",
    "@aafe/complex",
    "@aafe/dashboard",
    "@aafe/patterns",
    "@aafe/ddd",
    "@aafe/adapter-cursor",
    "@aafe/adapter-codebuddy"
  ],
  "rerun": {
    "enabled": true,
    "maxReruns": 1,
    "triggers": [
      "refactor-critic:fail",
      "merge_gate:fail"
    ]
  },
  "hooks": {
    "enabled": true,
    "sessionStart": ".cursor/hooks/aafe-session-start",
    "failClosed": false
  },
  "gates": [
    "ddd_gate",
    "architecture_gate",
    "pattern_gate",
    "implementation_gate",
    "merge_gate"
  ],
  "projectKnowledge": {
    "entry": ".ai-agent/project.md",
    "skills": ".ai-agent/project-skills",
    "rules": ".ai-agent/rules",
    "legacySharedRemoved": true,
    "selfUpdate": {
      "enabled": true,
      "skill": ".ai-agent/project-skills/aafe-self-update/SKILL.md",
      "rule": ".ai-agent/rules/knowledge-self-update.mdc",
      "updateOn": [
        "module_added",
        "module_updated",
        "route_changed",
        "api_contract_changed",
        "hook_changed",
        "component_pattern_changed",
        "stable_constraint_learned"
      ]
    }
  }
}
